# frontend/.env.production
# ============================================
# Production environment variables
# ============================================
#
# IMPORTANT: Do not add real values to this file!
# All values should be set in Vercel Dashboard:
#   Project → Settings → Environment Variables
#
# This file documents which variables the app needs.
# Vite will read values from Vercel's environment at build time.
#
# Required VITE_* variables (for frontend React app):
#   - VITE_API_URL
#   - VITE_SUPABASE_URL
#   - VITE_SUPABASE_ANON_KEY
#   - VITE_CLOUDINARY_CLOUD_NAME
#   - VITE_CLOUDINARY_API_KEY
#   - VITE_USE_SIGNED_IMAGES
#   - VITE_SENTRY_DSN (for error tracking)
#
# Required variables for Vercel Edge Functions (/api folder):
#   - BACKEND_API_URL
#   - BACKBLAZE_BUCKET_NAME
#   - BACKBLAZE_ENDPOINT
#   - BACKBLAZE_KEY_ID
#   - BACKBLAZE_APPLICATION_KEY
#
# ============================================
