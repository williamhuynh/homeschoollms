{
  "version": 2,
  "env": {
    "BACKEND_API_URL": "https://homeschoollms-server.onrender.com"
  },
  "rewrites": [
    {
      "source": "/api/files/signed-url",
      "destination": "https://homeschoollms-server.onrender.com/api/files/signed-url"
    },
    {
      "source": "/api/:path*",
      "destination": "https://homeschoollms-server.onrender.com/api/:path*"
    },
    {
      "source": "/curriculum/:file*",
      "destination": "/curriculum/:file*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "images": {
    "domains": ["homeschool-lms.vercel.app", "res.cloudinary.com"],
    "minimumCacheTTL": 60,
    "formats": ["image/avif", "image/webp"],
    "sizes": [16, 32, 48, 64, 96, 128, 256, 384, 640, 750, 828, 1080, 1200, 1920, 2048, 3840]
  }
}